---
import { Image } from 'astro:assets';
import Container from './ui/Container.astro';
import empwr from '../assets/portfolio/empwr.png';
---
<Container >
  <div id="portfolio" class="my-16 md:my-24 pb-20">
    <div class="text-center">
      <div class="text-primary text-4xl font-bold w-full">Portfolio</div>
      <p class="mt-3 w-full">Selected projects and products I've worked on</p>
    </div>
    <div class="w-full mt-10">
      <article class="mx-auto overflow-hidden">
        <div class="grid grid-cols-1 md:grid-cols-2">
          <div class="flex flex-col items-center">
            <div class="flex w-3/4 rounded-md">
              <Image
                src={empwr}
                class="h-full w-full object-contain rounded-md opacity-70"
                alt="EMPWR website preview"
              />
            </div>
          </div>
      
          <div class="flex flex-col justify-center mt-6 md:mt-0 md:w-3/4">
            <h3 class="text-xl font-semibold text-secondary">empwr</h3>
            <p class="mt-3 text-sm">
              empwr brings together more than a decade of industry leadership, creator excellence with an engaged community, and talent development prowess built for the modern creator economy.
            </p>
            <div class="mt-4 gap-3 flex">
              <span class="rounded-full border border-slate-600 px-3 py-1 text-xs text-slate-900">Next.js</span>
              <span class="rounded-full border border-slate-600 px-3 py-1 text-xs text-slate-900">Tailwind CSS</span>
            </div>
            <div class="mt-4 md:mt-2 flex justify-end">
              <a
                href="https://empwr.asia"
                target="_blank"
                rel="noreferrer"
                class="text-sm text-primary underline underline-offset-4 transition hover:opacity-80"
              >
                Visit site
              </a>
            </div>
          </div>
        </div>
      </article>
    </div>
  </div>
</Container>